# Database (Aiven MySQL) – replace with your real Service URI from Aiven (reveal password, then paste)
DATABASE_URL="mysql://user:password@hostname:3306/defaultdb?ssl-mode=REQUIRED"

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# Auth cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS (e.g. Vercel frontend URL)
CORS_ORIGIN=http://localhost:3000

# Server
PORT=4000
NODE_ENV=development

# Optional: AI Chat – Hugging Face fine-grained token with "Make calls to Inference Providers"
# Create at https://huggingface.co/settings/tokens (fine-grained, not classic Read).
# HUGGINGFACE_TOKEN=your-hf-token

# Optional: Ask AI on subject/video pages – free Gemini key (https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=your-gemini-key

# Optional: Judge0 CE API key (for Online Compiler – Java, C++, etc.)
# Get a free key at https://rapidapi.com/judge0-official/api/judge0-ce
# JUDGE0_AUTH_TOKEN=your-judge0-token
