# Database (Aiven MySQL)
DATABASE_URL="mysql://user:password@host:port/database?sslmode=require"

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# Auth cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS (e.g. Vercel frontend URL)
CORS_ORIGIN=http://localhost:3000

# Server
PORT=4000
NODE_ENV=development

# Optional: Ask AI (subject/video help) – free Gemini key only
# Get a key at https://aistudio.google.com/app/apikey (no credit card)
# GEMINI_API_KEY=your-gemini-key

# Optional: Judge0 CE API key (for Online Compiler – Java, C++, etc.)
# Get a free key at https://rapidapi.com/judge0-official/api/judge0-ce
# JUDGE0_AUTH_TOKEN=your-judge0-token
